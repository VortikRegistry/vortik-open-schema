{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/VortikRegistry/vortik-open-schema/blob/main/epbs-schema-v1.json",
  "title": "Vortik Open Schema — ePBS (EIP-7732) Semantic Anchor",
  "description": "Minimal metadata schema for an ePBS-aligned semantic anchor. Research artefact; not an official specification.",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "version", "identifier", "capabilities", "stewardship_status", "references"],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "ePBS",
      "description": "Protocol primitive label (semantic)."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(-[a-z0-9.-]+)?$",
      "default": "1.0-draft",
      "description": "Schema version (semver-ish)."
    },
    "identifier": {
      "type": "string",
      "const": "epbs.eth",
      "description": "ENS identifier mapped to this semantic anchor."
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["payload-commitment", "bid-standardization", "stewardship-metadata"]
      },
      "description": "Declared semantic capability tags (non-normative)."
    },
    "stewardship_status": {
      "type": "string",
      "enum": ["protocol_unanchored", "alignment_pending", "institutionally_reserved", "transferred"],
      "default": "alignment_pending",
      "description": "Institutional status label used by the registry (non-commercial)."
    },
    "references": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "format": "uri" },
      "default": [
        "https://eips.ethereum.org/EIPS/eip-7732",
        "https://ethresear.ch/t/epbs-design-constraints/18728"
      ],
      "description": "Primary-source references."
    }
  }
}
