{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/ssf/0.1-research/schema.json",
  "title": "Vortik Open Schema — Single-Slot Finality (SSF)",
  "description": "Machine-readable schema for the Single-Slot Finality (SSF) semantic anchor within the Vortik Semantic Registry. Research artefact; not an official protocol specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "canonical_term",
    "classification",
    "status",
    "type",
    "summary",
    "pipeline_position",
    "coordination_role",
    "protocol_grounding",
    "naming",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "ssf",
      "description": "Registry identifier for this semantic anchor."
    },
    "version": {
      "type": "string",
      "const": "0.1-research",
      "description": "Schema version for this anchor."
    },
    "canonical_term": {
      "type": "string",
      "const": "single-slot finality (SSF)",
      "description": "Canonical technical term tracked by this anchor."
    },
    "classification": {
      "type": "string",
      "const": "repairable",
      "description": "Semantic classification within the Vortik registry."
    },
    "status": {
      "type": "string",
      "const": "research",
      "description": "Current maturity/status of the tracked surface."
    },
    "type": {
      "type": "string",
      "const": "primitive",
      "description": "Structural type of this tracked surface."
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "description": "Short description of the surface."
    },
    "pipeline_position": {
      "type": "array",
      "description": "Pipeline stage where this primitive operates.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "order flow",
          "visibility",
          "builder coordination",
          "inclusion",
          "execution",
          "finality"
        ]
      }
    },
    "coordination_role": {
      "type": "array",
      "description": "Key coordination roles of SSF within Ethereum consensus.",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "protocol_grounding": {
      "type": "array",
      "description": "Primary protocol or research references grounding SSF.",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ens",
        "canonical",
        "mismatch",
        "notes"
      ],
      "properties": {
        "ens": {
          "type": "string",
          "const": "fastfinality.eth"
        },
        "canonical": {
          "type": "string",
          "const": "single-slot finality (SSF)"
        },
        "mismatch": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "sources": {
      "type": "array",
      "description": "Primary source references for this anchor.",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    }
  }
}
