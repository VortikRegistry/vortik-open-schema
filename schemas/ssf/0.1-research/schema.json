{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/ssf/0.1-research/schema.json",
  "title": "Vortik Open Schema — Single Slot Finality (SSF) Semantic Anchor",
  "description": "Minimal metadata schema for the SSF research surface. Research artefact; not an official specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "version",
    "identifier",
    "capabilities",
    "stewardship_status",
    "canonical_terms",
    "last_reviewed",
    "references"
  ],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "SSF",
      "description": "Semantic anchor label for Single Slot Finality research (non-normative)."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(-[a-z0-9.-]+)?$",
      "default": "0.1-research",
      "description": "Schema version (semver-ish)."
    },
    "identifier": {
      "type": "string",
      "const": "fastfinality.eth",
      "description": "ENS identifier mapped to this semantic anchor."
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "finality-reduction",
          "consensus-upgrade-surface",
          "stewardship-metadata"
        ]
      },
      "description": "Declared semantic capability tags (non-normative)."
    },
    "stewardship_status": {
      "type": "string",
      "enum": [
        "protocol_unanchored",
        "alignment_pending",
        "institutionally_reserved",
        "transferred"
      ],
      "default": "alignment_pending",
      "description": "Registry stewardship status label (non-commercial)."
    },
    "canonical_terms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 },
      "default": ["single-slot finality", "SSF"],
      "description": "Terms observed in primary sources for this research surface."
    },
    "terminology_evolution": {
      "type": "array",
      "description": "Non-normative timeline documenting terminology drift for this primitive.",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "status"],
        "properties": {
          "term": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["canonical", "alias", "deprecated"] },
          "notes": { "type": "string", "maxLength": 280 },
          "first_seen": { "type": "string", "format": "date" },
          "last_seen": { "type": "string", "format": "date" }
        }
      }
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "default": "2026-03-05",
      "description": "Last review date for this schema artefact (YYYY-MM-DD)."
    },
    "sources_md": {
      "type": "string",
      "format": "uri",
      "default": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/ssf/0.1-research/sources.md",
      "description": "Pointer to curated sources file (Markdown)."
    },
    "references": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "format": "uri" },
      "default": [
        "https://eips.ethereum.org/EIPS/eip-7251",
        "https://ethresear.ch/"
      ],
      "description": "Primary-source references (URIs)."
    },
    "notes": {
      "type": "string",
      "maxLength": 800,
      "description": "Optional notes for terminology ambiguity or scope boundaries."
    }
  }
}
