{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/commitmentlayer/0.1-draft/schema.json",
  "title": "Vortik Open Schema — Commitment Layer Semantic Anchor",
  "description": "Minimal metadata schema for L1 proposer commitments / preconfirmation coordination terminology. Research artefact; not an official specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "version",
    "identifier",
    "capabilities",
    "stewardship_status",
    "primitive_scope",
    "canonical_terms",
    "last_reviewed",
    "references"
  ],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "CommitmentLayer",
      "description": "Semantic anchor label for the commitment + preconfirmation coordination surface (non-normative)."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(-[a-z0-9.-]+)?$",
      "default": "0.1-draft",
      "description": "Schema version (semver-ish)."
    },
    "identifier": {
      "type": "string",
      "const": "commitmentlayer.eth",
      "description": "ENS identifier mapped to this semantic anchor."
    },
    "primitive_scope": {
      "type": "string",
      "minLength": 20,
      "description": "Scope definition: what this anchor covers and what it explicitly does not cover."
    },
    "canonical_terms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 },
      "description": "Terms observed in primary sources for this concept surface."
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "commitment-signals",
          "preconfirmation-coordination",
          "stewardship-metadata"
        ]
      },
      "description": "Declared semantic capability tags (non-normative)."
    },
    "stewardship_status": {
      "type": "string",
      "enum": [
        "protocol_unanchored",
        "alignment_pending",
        "institutionally_reserved",
        "transferred"
      ],
      "default": "alignment_pending",
      "description": "Registry stewardship status label (non-commercial)."
    },
    "terminology_evolution": {
      "type": "array",
      "description": "Non-normative timeline documenting terminology drift for this primitive surface.",
      "default": [
        {
          "term": "proposer commitments",
          "status": "alias",
          "notes": "Early research terminology emphasizing proposer-side commitment mechanisms in preconfirmation and neutrality discussions.",
          "first_seen": "2024-01-01"
        },
        {
          "term": "commitment layer",
          "status": "canonical",
          "notes": "Broader coordination-surface term used to describe commitment signaling and related preconfirmation infrastructure.",
          "first_seen": "2024-06-01"
        },
        {
          "term": "preconfirmation commitments",
          "status": "alias",
          "notes": "Used when the commitment surface is described specifically through preconfirmation guarantees or commitment flows.",
          "first_seen": "2024-06-01"
        }
      ],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "status"],
        "properties": {
          "term": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["canonical", "alias", "deprecated"] },
          "notes": { "type": "string", "maxLength": 280 },
          "first_seen": { "type": "string", "format": "date" },
          "last_seen": { "type": "string", "format": "date" }
        }
      }
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "default": "2026-03-05",
      "description": "Last review date for this schema artefact (YYYY-MM-DD)."
    },
    "sources_md": {
      "type": "string",
      "format": "uri",
      "default": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/commitmentlayer/0.1-draft/sources.md",
      "description": "Pointer to curated sources file (Markdown)."
    },
    "references": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "format": "uri" },
      "default": [
        "https://ethresear.ch/t/uncrowdable-inclusion-lists-the-tension-between-chain-neutrality-preconfirmations-and-proposer-commitments/19372",
        "https://ethresear.ch/t/becoming-based-a-path-towards-decentralised-sequencing/21733"
      ],
      "description": "Primary-source references (URIs)."
    },
    "notes": {
      "type": "string",
      "maxLength": 800,
      "description": "Optional notes for ambiguity or naming collisions."
    }
  }
}
