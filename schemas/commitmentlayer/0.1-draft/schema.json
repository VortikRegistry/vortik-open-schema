{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/commitmentlayer/0.1-draft/schema.json",
  "title": "Vortik Open Schema — Commitment Signaling / Preconfirmation Commitments",
  "description": "Machine-readable schema for the Commitment Signaling / Preconfirmation Commitments semantic anchor within the Vortik Semantic Registry. Research artifact; not an official protocol specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "canonical_term",
    "classification",
    "status",
    "type",
    "summary",
    "pipeline_position",
    "coordination_role",
    "protocol_grounding",
    "naming",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "commitmentlayer",
      "description": "Registry identifier for this semantic anchor."
    },
    "version": {
      "type": "string",
      "const": "0.1-draft",
      "description": "Schema version for this anchor."
    },
    "canonical_term": {
      "type": "string",
      "const": "commitment signaling / preconfirmation commitments",
      "description": "Canonical technical term tracked by this anchor."
    },
    "classification": {
      "type": "string",
      "const": "repairable",
      "description": "Semantic classification within the Vortik registry."
    },
    "status": {
      "type": "string",
      "const": "research",
      "description": "Current maturity/status of the tracked surface."
    },
    "type": {
      "type": "string",
      "const": "coordination-surface",
      "description": "Emergent coordination surface rather than a discrete protocol mechanism."
    },
    "summary": {
      "type": "string",
      "description": "Short description of the surface.",
      "minLength": 20
    },
    "pipeline_position": {
      "type": "array",
      "description": "Interpretive position within the coordination pipeline.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "order flow",
          "solver coordination",
          "builder coordination",
          "preconfirmation",
          "inclusion"
        ]
      }
    },
    "coordination_role": {
      "type": "array",
      "description": "Key coordination functions performed by commitment signaling mechanisms.",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "protocol_grounding": {
      "type": "array",
      "description": "Primary protocol or research references grounding this surface.",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ens",
        "canonical",
        "mismatch",
        "notes"
      ],
      "properties": {
        "ens": {
          "type": "string",
          "const": "commitmentlayer.eth"
        },
        "canonical": {
          "type": "string",
          "const": "commitment signaling / preconfirmation commitments"
        },
        "mismatch": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "sources": {
      "type": "array",
      "description": "Primary source references for this anchor.",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    }
  }
}
