{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/executionmarket/0.1-research/schema.json",
  "title": "Vortik Open Schema — Execution Coordination (Ambiguous Term)",
  "description": "Machine-readable schema for the Execution Coordination semantic anchor within the Vortik Semantic Registry. Research artifact; not an official protocol specification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "canonical_term",
    "classification",
    "status",
    "type",
    "summary",
    "pipeline_position",
    "coordination_role",
    "protocol_grounding",
    "naming",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "executionmarket",
      "description": "Registry identifier for this semantic anchor."
    },
    "version": {
      "type": "string",
      "const": "0.1-research",
      "description": "Schema version for this anchor."
    },
    "canonical_term": {
      "type": "string",
      "const": "execution coordination (ambiguous term)",
      "description": "Current registry term used to track an unstable and non-canonical execution-surface concept."
    },
    "classification": {
      "type": "string",
      "const": "premature",
      "description": "Semantic classification within the Vortik registry."
    },
    "status": {
      "type": "string",
      "const": "research",
      "description": "Current maturity/status of the tracked surface."
    },
    "type": {
      "type": "string",
      "const": "ambiguous-surface",
      "description": "Provisional structural type used for an unstable and non-canonical coordination concept."
    },
    "summary": {
      "type": "string",
      "description": "Short description of the surface.",
      "minLength": 20
    },
    "pipeline_position": {
      "type": "array",
      "description": "Interpretive pipeline stages where this surface is most commonly associated.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "order flow",
          "solver coordination",
          "builder coordination",
          "execution"
        ]
      }
    },
    "coordination_role": {
      "type": "array",
      "description": "Key coordination functions tentatively attributed to this surface.",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "protocol_grounding": {
      "type": "array",
      "description": "Primary protocol or research references grounding this surface.",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ens",
        "canonical",
        "mismatch",
        "notes"
      ],
      "properties": {
        "ens": {
          "type": "string",
          "const": "executionmarket.eth"
        },
        "canonical": {
          "type": "string",
          "const": "execution coordination (ambiguous term)"
        },
        "mismatch": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "sources": {
      "type": "array",
      "description": "Primary source references for this anchor.",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    }
  }
}
