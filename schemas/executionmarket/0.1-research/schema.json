{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/executionmarket/0.1-research/schema.json",
  "title": "Vortik Open Schema — Execution Market Semantic Anchor",
  "description": "Minimal metadata schema describing execution market coordination layers emerging across Ethereum execution infrastructure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "version",
    "identifier",
    "primitive_scope",
    "canonical_terms",
    "capabilities",
    "stewardship_status",
    "last_reviewed",
    "references"
  ],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "ExecutionMarket",
      "description": "Semantic anchor representing execution market coordination structures."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(-[a-z0-9.-]+)?$",
      "default": "0.1-research"
    },
    "identifier": {
      "type": "string",
      "const": "executionmarket.eth",
      "description": "ENS identifier mapped to this semantic anchor."
    },
    "primitive_scope": {
      "type": "string",
      "minLength": 20,
      "description": "Execution coordination layer where solver agents, builders and other actors interact to determine optimal transaction execution pathways."
    },
    "canonical_terms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "execution-routing",
          "liquidity-discovery",
          "auction-participation",
          "intent-resolution",
          "stewardship-metadata"
        ]
      }
    },
    "stewardship_status": {
      "type": "string",
      "enum": [
        "protocol_unanchored",
        "alignment_pending",
        "institutionally_reserved",
        "transferred"
      ],
      "default": "alignment_pending"
    },
    "terminology_evolution": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "status"],
        "properties": {
          "term": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["canonical", "alias", "deprecated"]
          },
          "notes": {
            "type": "string",
            "maxLength": 280
          },
          "first_seen": {
            "type": "string",
            "format": "date"
          },
          "last_seen": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "default": "2026-03-15"
    },
    "sources_md": {
      "type": "string",
      "format": "uri",
      "default": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/executionmarket/0.1-research/sources.md"
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 800
    }
  }
}
