{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "registry",
    "version",
    "description",
    "source_of_truth",
    "anchors"
  ],
  "properties": {
    "registry": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "source_of_truth": {
      "type": "string",
      "enum": ["schemas"]
    },
    "last_updated": {
      "type": "string"
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "ens",
          "canonical_term",
          "classification",
          "status",
          "type",
          "role",
          "schema",
          "anchor_doc"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "ens": {
            "type": "string"
          },
          "canonical_term": {
            "type": "string"
          },
          "classification": {
            "type": "string",
            "enum": [
              "core",
              "valid",
              "repairable",
              "premature"
            ]
          },
          "status": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "primitive",
              "mechanism",
              "market"
            ]
          },
          "role": {
            "type": "string"
          },
          "schema": {
            "type": "string"
          },
          "anchor_doc": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "external_primitives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "canonical_term",
          "category",
          "coverage_status",
          "ens_status",
          "status",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "canonical_term": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "primitive",
              "market",
              "standard",
              "coordination-surface",
              "mechanism"
            ]
          },
          "coverage_status": {
            "type": "string"
          },
          "ens_status": {
            "type": "string"
          },
          "desired_ens": {
            "type": ["string", "null"]
          },
          "status": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
