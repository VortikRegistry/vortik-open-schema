{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "anchors"],
  "properties": {
    "version": {
      "type": "string"
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "ens",
          "canonical_term",
          "classification",
          "status",
          "schema",
          "anchor_doc"
        ],
        "properties": {
          "id": { "type": "string" },
          "ens": { "type": "string" },
          "canonical_term": { "type": "string" },
          "classification": {
            "type": "string",
            "enum": [
              "core",
              "valid",
              "premature",
              "speculative",
              "repairable",
              "external"
            ]
          },
          "type": {
            "type": "string",
            "enum": ["primitive", "role", "market", "research"]
          },
          "role": { "type": "string" },
          "status": { "type": "string" },
          "schema": { "type": "string" },
          "anchor_doc": { "type": "string" },
          "external_primitives": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
