{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vortik Semantic Registry Schema",
  "type": "object",
  "required": [
    "registry",
    "version",
    "description",
    "source_of_truth",
    "last_updated",
    "anchors"
  ],
  "properties": {
    "registry": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source_of_truth": {
      "type": "string",
      "enum": [
        "schemas"
      ]
    },
    "last_updated": {
      "type": "string",
      "minLength": 1
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "ens",
          "canonical_term",
          "classification",
          "status",
          "status_label",
          "stage",
          "market_priority",
          "type",
          "role",
          "schema",
          "anchor_doc",
          "market"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "ens": {
            "type": "string",
            "pattern": "^[a-z0-9-]+\\.eth$"
          },
          "canonical_term": {
            "type": "string",
            "minLength": 1
          },
          "classification": {
            "type": "string",
            "enum": [
              "core",
              "repairable",
              "premature",
              "deprecated",
              "external"
            ]
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "status_label": {
            "type": "string",
            "enum": [
              "core",
              "canonical",
              "emerging",
              "transitional",
              "repairable",
              "premature",
              "deprecated",
              "external"
            ]
          },
          "stage": {
            "type": "string",
            "enum": [
              "canonical",
              "implemented",
              "emerging",
              "research",
              "transitional",
              "external",
              "legacy",
              "deprecated"
            ]
          },
          "market_priority": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "primitive",
              "constraint",
              "mechanism",
              "market",
              "role",
              "coordination_surface",
              "external_actor",
              "external_mechanism",
              "misaligned_abstraction"
            ]
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "schema": {
            "type": "string",
            "pattern": "^schemas\\/.+\\/schema\\.json$"
          },
          "anchor_doc": {
            "type": "string",
            "pattern": "^anchors\\/.+\\.md$"
          },
          "market": {
            "type": "object",
            "required": [
              "priority",
              "sale_strategy",
              "visibility"
            ],
            "properties": {
              "priority": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "sale_strategy": {
                "type": "string",
                "enum": [
                  "strategic_custody",
                  "selective_inquiry",
                  "transfer_ready"
                ]
              },
              "visibility": {
                "type": "string",
                "enum": [
                  "featured",
                  "standard",
                  "background",
                  "hidden"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "external_primitives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "canonical_term",
          "category",
          "coverage_status",
          "ens_status",
          "status",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "canonical_term": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "primitive",
              "market",
              "standard",
              "coordination-surface",
              "coordination_surface",
              "mechanism"
            ]
          },
          "coverage_status": {
            "type": "string",
            "minLength": 1
          },
          "ens_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "desired_ens": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
