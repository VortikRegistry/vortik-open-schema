{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vortikregistry.github.io/vortik-open-schema/registry.schema.json",
  "title": "Vortik Semantic Registry",
  "type": "object",
  "required": ["registry", "version", "description", "anchors"],
  "additionalProperties": false,
  "properties": {
    "registry": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/anchor"
      }
    }
  },
  "$defs": {
    "anchor": {
      "type": "object",
      "required": ["id", "ens", "layer", "status", "schema", "anchor_doc"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
        },
        "ens": {
          "type": "string",
          "pattern": "^[a-z0-9-]+\\.eth$"
        },
        "layer": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft-eip", "research", "deprecated"]
        },
        "schema": {
          "type": "string",
          "pattern": "^schemas\\/.*\\/.*\\/schema\\.json$"
        },
        "anchor_doc": {
          "type": "string",
          "pattern": "^anchors\\/.*\\.md$"
        }
      }
    }
  }
}
