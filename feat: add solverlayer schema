{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/solverlayer/0.1-research/schema.json",
  "title": "Vortik Open Schema — Solver Layer Semantic Anchor",
  "description": "Minimal metadata schema describing intent solver coordination layers emerging across Ethereum execution infrastructure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "version",
    "identifier",
    "primitive_scope",
    "canonical_terms",
    "capabilities",
    "stewardship_status",
    "last_reviewed",
    "references"
  ],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "SolverLayer",
      "description": "Semantic anchor label representing intent solver coordination networks."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(-[a-z0-9.-]+)?$",
      "default": "0.1-research",
      "description": "Schema version identifier."
    },
    "identifier": {
      "type": "string",
      "const": "solverlayer.eth",
      "description": "ENS identifier mapped to this semantic anchor."
    },
    "primitive_scope": {
      "type": "string",
      "minLength": 20,
      "description": "Coordination layer where solver agents compute optimal execution paths for user intents across execution infrastructure and liquidity sources."
    },
    "canonical_terms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2
      },
      "description": "Terms observed in research describing solver coordination layers."
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "intent-resolution",
          "execution-routing",
          "liquidity-discovery",
          "auction-participation",
          "stewardship-metadata"
        ]
      },
      "description": "Declared semantic capability tags."
    },
    "stewardship_status": {
      "type": "string",
      "enum": [
        "protocol_unanchored",
        "alignment_pending",
        "institutionally_reserved",
        "transferred"
      ],
      "default": "alignment_pending",
      "description": "Registry stewardship lifecycle state."
    },
    "terminology_evolution": {
      "type": "array",
      "description": "Timeline describing terminology drift around solver networks.",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "term",
          "status"
        ],
        "properties": {
          "term": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "canonical",
              "alias",
              "deprecated"
            ]
          },
          "notes": {
            "type": "string",
            "maxLength": 280
          },
          "first_seen": {
            "type": "string",
            "format": "date"
          },
          "last_seen": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "default": "2026-03-15",
      "description": "Last review date for this schema."
    },
    "sources_md": {
      "type": "string",
      "format": "uri",
      "default": "https://raw.githubusercontent.com/VortikRegistry/vortik-open-schema/main/schemas/solverlayer/0.1-research/sources.md",
      "description": "Pointer to curated source references."
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "Primary research references."
    },
    "notes": {
      "type": "string",
      "maxLength": 800,
      "description": "Optional notes describing semantic boundaries or overlaps."
    }
  }
}
