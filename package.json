{
  "name": "vortik-open-schema",
  "version": "0.6.5",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "npm run validate:json && npm run validate:registry-schema && npm run validate:registry && npm run validate:maps && npm run validate:semantic-status && npm run validate:integrity && npm run validate:derived-sync && npm run check:public-safety",
    "validate:json": "node scripts/validate-json-files.mjs",
    "validate:registry": "node scripts/validate-registry.mjs",
    "validate:maps": "node scripts/validate-map-coverage.mjs",
    "validate:integrity": "node scripts/validate-integrity.mjs",
    "validate:derived-sync": "node scripts/validate-derived-sync.mjs",
    "fix:schemas": "node scripts/fix-schemas.cjs",
    "generate:map": "node scripts/generate-map.mjs",
    "generate:anchors-index": "node scripts/generate-anchors-index.mjs",
    "sync:docs": "node scripts/sync-docs.mjs",
    "check": "npm run fix:schemas && npm run validate",
    "check:public-safety": "node scripts/check-public-safety.mjs",
    "validate:semantic-status": "node scripts/validate-semantic-status-sync.mjs",
    "validate:registry-schema": "node scripts/validate-registry-schema.mjs"
  },
  "devDependencies": {
    "ajv": "^8.17.1"
  }
}
